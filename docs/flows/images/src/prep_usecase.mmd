flowchart LR
    Admin(["ADMIN / OPS"])
    Superadmin(["SUPERADMIN"])
    
    subgraph System["Sistem Penjadwalan (Departure)"]
        direction TB
        A((Buat Master Rute & Armada))
        B((Input Template Recurrence Jadwal))
        C((Eksekusi Tombol Generate Slot))
        D((Assign Supir & Kendaraan ke Manifest))
    end
    
    Superadmin ---> A
    Admin ---> B
    Admin ---> C
    Admin ---> D
    Superadmin ---> D
    
    classDef actor fill:#f3e5f5,stroke:#8e24aa,stroke-width:2px;
    classDef usecase fill:#e1f5fe,stroke:#039be5,stroke-width:2px;
    classDef system fill:#ffffff,stroke:#bdbdbd,stroke-width:2px,stroke-dasharray: 5 5;
    
    class Admin,Superadmin actor;
    class A,B,C,D usecase;
    class System system;
