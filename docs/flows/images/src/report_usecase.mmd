flowchart LR
    Management(["MANAGEMENT / SUPERADMIN"])
    
    subgraph System["Sistem Data Warehouse (Reporting)"]
        direction TB
        A((Pilih Filter Rentang Waktu))
        B((Pilih Filter Outlet / Rute))
        C((Request Render Query))
        D((Tampilkan Kompilasi Tiket & Paket))
    end
    
    Management ---> A
    Management ---> B
    Management ---> C
    System -.-> D
    
    classDef actor fill:#f3e5f5,stroke:#8e24aa,stroke-width:2px;
    classDef usecase fill:#e1f5fe,stroke:#039be5,stroke-width:2px;
    classDef system fill:#ffffff,stroke:#bdbdbd,stroke-width:2px,stroke-dasharray: 5 5;
    
    class Management actor;
    class A,B,C,D usecase;
    class System system;
